# Ignorar las dependencias (muy importante)
node_modules/

# Archivos de sistema y logs
.DS_Store
Thumbs.db
*.log

# Archivos de variables de entorno (seguridad)
.env

# Certificados/llaves privadas de QZ Tray
config/qz/*.pem
certs/qz/*.pem
!config/qz/*.example.pem
!certs/qz/*.example.pem

# NEW: uploads locales generados por el modulo Inventario.
# WHY: las imagenes subidas viven en disco local y no deben versionarse.
# IMPACT: evita ruido de archivos binarios en git; no afecta la carga en runtime.
uploads/
