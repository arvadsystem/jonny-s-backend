API_BASE_URL=https://qa-api.example.com
PRINT_AGENT_ID=00000000-0000-0000-0000-000000000000
PRINT_AGENT_TOKEN=replace_with_provisioned_token
BRANCH_ID=1
QZ_HOST=localhost
QZ_SECURE_PORT=8181
QZ_CA_CERT_PATH=C:\ProgramData\JonnysPrintAgent\qz-local-ca.pem
# No subir todavia a 60000. El servidor WebSocket es en memoria por proceso (ver
# services/printAgentWebSocketService.js): un agente conectado a una replica "web" nunca
# recibe job_available si el trabajo se encolo mientras una request cayo en otra replica.
# docs/deployment-runtime.md fija "una sola replica" solo para el rol scheduler; el rol
# web no tiene ese limite y config/db-connection.js ya asume explicitamente mas de una
# ("Keep the per-process pool conservative because every replica creates one"). Mientras
# no exista un mecanismo de notificacion compartido entre replicas (pub/sub, Realtime,
# etc., fuera de alcance actual), este polling de 3s sigue siendo la unica garantia
# valida de que ningun trabajo espera mas de POLL_INTERVAL_MS sin importar a que replica
# conecto el agente.
POLL_INTERVAL_MS=3000
HEARTBEAT_INTERVAL_MS=30000
LEASE_SECONDS=90
# false (o ausente) = solo polling, comportamiento actual. true = WebSocket activo como
# notificacion inmediata; el polling cada POLL_INTERVAL_MS sigue como respaldo.
PRINT_AGENT_WEBSOCKET_ENABLED=false
PRINTER_MAP_JSON={"factura":"Printer name","cocina":"Kitchen printer","caja":"Cash printer"}
LOG_DIR=./logs
PRINT_STATE_FILE=./data/print-state.json
