FRONTEND_ORIGIN=
FRONTEND_ORIGINS=
BACKEND_PUBLIC_ORIGIN=
SUPABASE_URL=
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=none
AUTH_COOKIE_DOMAIN=
DB_POOL_MAX=5
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=3000
DB_KEEP_ALIVE=true
DB_KEEP_ALIVE_INITIAL_DELAY_MS=10000
DB_APPLICATION_NAME=jonnys-backend
DB_TRANSACTION_STATEMENT_TIMEOUT_MS=15000
DB_TRANSACTION_LOCK_TIMEOUT_MS=6000
DB_IDLE_IN_TRANSACTION_TIMEOUT_MS=5000
DB_SLOW_TRANSACTION_MS=3000
CAJAS_FINANCIAL_LOCK_TIMEOUT_MS=5000
# Destinatario de reportes de cierre de caja por ambiente.
# QA: arvadsystem@gmail.com
# Producción: dejar vacío para conservar el destinatario actual.
CAJA_CLOSE_EMAIL_TO=
CAJA_CLOSE_EMAIL_OUTBOX_INTERVAL_MS=15000
CAJA_CLOSE_EMAIL_OUTBOX_BATCH_SIZE=5
PROCESS_ROLE=web
EMAIL_SCHEDULER_ENABLED=false
VENTAS_USE_RPC_V3=false
PEDIDO_PENDIENTE_USE_RPC_V2=false
# Web replica: PROCESS_ROLE=web, DB_POOL_MAX=5, EMAIL_SCHEDULER_ENABLED=false
# Scheduler replica: PROCESS_ROLE=scheduler, DB_POOL_MAX=2, EMAIL_SCHEDULER_ENABLED=true
QZ_TRAY_CERTIFICATE_PATH=/run/secrets/qz/digital-certificate.txt
QZ_TRAY_PRIVATE_KEY_PATH=/run/secrets/qz/private-key.pem
QZ_SIGNATURE_ALGORITHM=SHA512
# Notificacion WebSocket aditiva de "job_available" para agentes de impresion.
# false (o ausente) = comportamiento actual, solo polling del agente. true = WS activo,
# polling sigue como respaldo. Ver services/printAgentWebSocketService.js.
PRINT_AGENT_WEBSOCKET_ENABLED=false
# Durante el despliegue gradual mantener false.
# Cambiar a true cuando todos los frontend estén actualizados.
QZ_REQUIRE_SUCURSAL_CONTEXT=false
# Certificado específico opcional por sucursal
QZ_TRAY_CERTIFICATE_TEXT_SUCURSAL_1=
QZ_TRAY_PRIVATE_KEY_PEM_SUCURSAL_1=
